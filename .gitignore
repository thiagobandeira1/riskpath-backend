# --- Data ---------------------------------------------------------------
# The MIMIC-IV-derived parquet files in data/ are research data subject to
# the PhysioNet Data Use Agreement. They MUST NEVER be committed to a
# public repository. If you ever `git init` this folder, double-check this
# rule survives.
data/

# --- Python -------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.ipynb_checkpoints/

# --- Virtual environments ----------------------------------------------
venv/
.venv/
env/
.env

# --- Editors / OS ------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Optional: exclude large model artefacts ---------------------------
# Uncomment if model files grow too large for the repo, OR if they should
# be re-downloaded from a model registry instead of being version-controlled.
# model/*.pkl
# model/*.joblib

# --- Build / package artefacts ----------------------------------------
build/
dist/
*.egg-info/

# --- Frontend: TEMPORARY EXCLUSION during stack evaluation ------------
# Multiple frontend attempts (Claude Design, Lovable, etc.) land here
# while we pick a winner. Keeps experiments out of git history so the
# backend log stays clean. When the winner is picked, REMOVE this block
# and commit ./frontend/ as a single labeled slice. At that point also
# add the Node-specific paths back:
#   frontend/node_modules/
#   frontend/dist/
#   frontend/.vite/
frontend/

# --- Regenerable / DUA-sensitive artifacts at project root ------------
# openapi.json: regenerable via `python -c "..." > openapi.json`.
# example_payload.json: contains ONE real MIMIC-derived patient row
#   (used to brief Claude Design / Lovable on the request shape).
#   The PhysioNet DUA prohibits redistribution — MUST stay local.
openapi.json
example_payload.json
